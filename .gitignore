# --- secrets / local config (never commit) ---
.env
.env.*
!.env.example
*.key
*.pem

# --- local runtime data (confidential cache/graph store) ---
*.sqlite
*.sqlite3
*.db
data/
.parcus/
.cache/

# --- codebase-memory MCP index (optional dev aid; regenerated locally, never vendored) ---
.codebase-memory/

# --- python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.python-version

# --- test / coverage / type / lint caches ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.mypy_cache/
.ruff_cache/
.hypothesis/
mutants/
.mutmut-cache

# --- local model artifacts (lazy-downloaded, not vendored) ---
models/
*.gguf
*.onnx
*.safetensors

# --- docs build output (built in CI, not committed) ---
site/
docs/_build/

# --- editor / OS ---
.idea/
.vscode/
*.swp
.DS_Store
