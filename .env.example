# parsimony local config — copy to .env (git-ignored). Placeholders only; NO real secrets.

# --- Upstream provider endpoints (where the proxy forwards to) ---
PARSIMONY_ANTHROPIC_UPSTREAM=https://api.anthropic.com
PARSIMONY_OPENAI_UPSTREAM=https://api.openai.com

# --- Provider API keys ---
# Preferred: leave these UNSET and let the harness send Authorization/x-api-key headers,
# which the proxy forwards verbatim (it never logs or stores them). Only set a key here if you
# want the proxy to inject it. Never commit a real key.
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# --- Bind address (loopback + tailnet only; NEVER 0.0.0.0/public) ---
PARSIMONY_HOST=127.0.0.1
PARSIMONY_PORT=8787
# Optional tailnet IP to also bind (find with `tailscale ip -4`)
# PARSIMONY_TAILNET_IP=100.x.y.z

# --- Compression ---
PARSIMONY_LOSSLESS=true          # Tier-0 lossless pass (safe, default on)
PARSIMONY_FILLER=false           # Tier-1 filler removal (opt-in, guardrailed)
PARSIMONY_LEARNED=false          # Tier-2 local learned compressor (opt-in, local model)

# --- Cache ---
PARSIMONY_CACHE=true             # exact/normalized-hash response cache
PARSIMONY_CACHE_TTL_SECONDS=86400
PARSIMONY_CACHE_PATH=.parsimony/cache.sqlite
# Comma-separated regexes; matching requests are NEVER cached (e.g. auth flows)
PARSIMONY_CACHE_NOCACHE_PATTERNS=

# --- Privacy / redaction ---
PARSIMONY_REDACT=true            # redact secrets/PII before persisting cache/graph

# --- Observability ---
PARSIMONY_LOG_LEVEL=INFO
PARSIMONY_METRICS=true           # emit per-turn token-savings metrics
