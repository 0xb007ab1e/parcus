# parsimony local config — copy to .env (git-ignored). Placeholders only; NO real secrets.

# --- Upstream provider endpoints (where the proxy forwards to) ---
PARSIMONY_ANTHROPIC_UPSTREAM=https://api.anthropic.com
PARSIMONY_OPENAI_UPSTREAM=https://api.openai.com

# --- Provider API keys ---
# Preferred: leave these UNSET and let the harness send Authorization/x-api-key headers,
# which the proxy forwards verbatim (it never logs or stores them). Only set a key here if you
# want the proxy to inject it. Never commit a real key.
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# --- Bind address (loopback + tailnet only; NEVER 0.0.0.0/public) ---
PARSIMONY_HOST=127.0.0.1
PARSIMONY_PORT=8787
# Optional tailnet IP to also bind (find with `tailscale ip -4`)
# PARSIMONY_TAILNET_IP=100.x.y.z

# --- Compression ---
PARSIMONY_LOSSLESS=true          # Tier-0 lossless pass (safe, default on)
PARSIMONY_FILLER=false           # Tier-1 filler removal (opt-in, guardrailed)
PARSIMONY_LEARNED=false          # Tier-2 local learned compressor (opt-in, local model)

# --- Cache ---
PARSIMONY_CACHE=true             # exact/normalized-hash response cache
PARSIMONY_CACHE_TTL_SECONDS=86400
PARSIMONY_CACHE_PATH=.parsimony/cache.sqlite
# Comma-separated regexes; matching requests are NEVER cached (e.g. auth flows)
PARSIMONY_CACHE_NOCACHE_PATTERNS=

# --- Semantic (near-duplicate) cache — OFF by default; trades correctness for tokens ---
# On an exact miss, serve a cached response for a SIMILAR request (same model + tenant) when
# cosine >= threshold. Validate the threshold first: `parsimony eval --similarity`.
PARSIMONY_SIMILARITY_CACHE=false
PARSIMONY_SIMILARITY_THRESHOLD=0.97   # cosine in [0,1]; high = near-duplicate only
PARSIMONY_SIMILARITY_MAX_ENTRIES=2048
# hashing is LEXICAL (dep-free) — unsafe alone (can't tell "10 replicas" from "2"); 'local'
# (sentence-transformers extra) is the safe semantic choice. Validate with `eval --similarity`.
PARSIMONY_SIMILARITY_EMBEDDER=hashing

# --- At-rest cache encryption — OFF by default; opt-in defense-in-depth (AES-256-GCM) ---
# Encrypts cached response bodies on disk. Key = base64(32 bytes), from env OR a keyfile (never
# in VCS). Enabling without a valid key fails closed at startup. Requires the 'encryption' extra.
#   gen a key:  python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
PARSIMONY_CACHE_ENCRYPTION=false
PARSIMONY_CACHE_ENCRYPTION_KEY=
PARSIMONY_CACHE_ENCRYPTION_KEYFILE=

# --- Privacy / redaction ---
PARSIMONY_REDACT=true            # redact secrets/PII before persisting cache/graph

# --- Observability ---
PARSIMONY_LOG_LEVEL=INFO
PARSIMONY_METRICS=true           # emit per-turn token-savings metrics
PARSIMONY_INVARIANT_SAMPLE_RATE=1.0  # fraction of requests to run the per-stage invariant self-check

# --- Graph memory (Track B) — OFF by default; injection changes the request, so it is opt-in ---
PARSIMONY_MEMORY=false           # ingest requests into the memory graph
PARSIMONY_MEMORY_INJECT=false    # Track B: compact long histories via retrieval (needs MEMORY=true)
PARSIMONY_MEMORY_SUMMARIZE=false # Track C: replace older turns with a rolling summary (needs MEMORY=true)
PARSIMONY_MEMORY_KEEP_RECENT=4   # most-recent messages kept verbatim when compacting
PARSIMONY_MEMORY_RETRIEVE=3      # max retrieved snippets injected (Track B)
PARSIMONY_MEMORY_SUMMARY_ITEMS=5 # max summary points (Track C)
PARSIMONY_MEMORY_MIN_MESSAGES=8  # only compact requests longer than this

# --- Hosted / multi-tenant mode — OFF by default (local single-user is the default) ---
# When true, the tenant is derived server-side from the inbound credential (never a client
# field) and the response cache is namespaced per tenant so tenants never share cached data.
PARSIMONY_MULTI_TENANT=false
# Optional edge authorization (requires MULTI_TENANT=true). Comma-separated allow-list of
# permitted tenant ids; empty = open (the provider still authenticates the forwarded key).
# Build ids without exposing keys on argv:  PARSIMONY_TENANT_CREDENTIAL=sk-... parsimony tenant-id
PARSIMONY_ALLOWED_TENANTS=
# Optional per-tenant rate limit (token bucket). 0 = disabled. Keyed by the derived tenant id
# (one shared bucket in single-tenant mode). Over-limit requests get 429 + Retry-After, never
# forwarded. Burst 0 defaults capacity to one minute's worth.
PARSIMONY_RATE_LIMIT_PER_MINUTE=0
PARSIMONY_RATE_LIMIT_BURST=0
